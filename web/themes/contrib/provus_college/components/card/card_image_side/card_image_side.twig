<div class="card-wrapper provus-card-{{ image_position }}">
<div{% if content_attributes is defined and content_attributes %}{{ content_attributes.addClass('card') }}{% else %} class="card"{% endif %}>
{% if header|render %}
  <div class="card-header">
    {{ header }}
  </div>
{% endif %}
  <div class="card-content">
    {% if image_url %}
      <div class="card-img img-fluid">
        <div class="card-img-container position-left" style="background-image: url({{ image_url.src }})"></div>
        <img src="{{ image_url.src }}" alt="{{ image_url.alt }}">
      </div>
    {% endif %}
    <div class="card-body">
      {% if title|render or body|render %}
        <div class="card-content">
          {% if title|render %}
            <h3 class="card-title">{{ title }}</h3>
          {% endif %}
          {% if body|render %}
            <div class="card-text">{{ body|raw }}</div>
          {% endif %}
        </div>
      {% endif %}
      {% if more_content|render or (link_text and link_url) %}
      <div class="card-extra">
        {% if more_content|render %}
        {{ more_content|raw }}
        {% endif %}
        
        {% if link_text and link_url %}
          <div class="field field--name-field-provus-links field--type-link field__items">
            <a href="{{ link_url }}" class="{{ link_style ? 'btn btn-' ~ link_style : '' }}">{{ link_text }}</a>
          </div>
        {% endif %}
      </div>
      {% endif %}
    </div>
  </div>
</div>
</div>
