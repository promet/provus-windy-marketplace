<div class="testimonial-wrapper image-location-{{ display_type }}">
  <div{% if content_attributes is defined and content_attributes %}{{ content_attributes.addClass('card card-testimonial') }}{% else %} class="card card-testimonial"{% endif %}>
    <div class="row">
      {% if image_url %}
        <div class="col-lg-6">
      {% else %}
        <div class="col-lg-12">
      {% endif %}
        <div class="testimonial-content">
          {% if body|render %}
            <div class="testimonial-body">{{ body }}</div>
          {% endif %}
          {% if name %}
            <div class="testimonial-name">
              {{ name }}
            </div>
          {% endif %}
          {% if role %}
            <div class="testimonial-role">
              {{ role }}
            </div>
          {% endif %}
        </div>
      </div>
      {% if image_url %}
        <div class="col-lg-6">
            <div class="testimonial-image">
              {% set styled_media = image_url|provus_apply_image_style('testimonial_image_style')|default({}) %}
              {% include 'canvas:image' with styled_media only %}
            </div>
        </div>
      {% endif %}
    </div>
  </div>
</div>