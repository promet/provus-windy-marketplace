<div class="card-wrapper provus-{{ card_type == 'plus' ? 'card-plus' : 'card' }}">
  <div{% if content_attributes is defined and content_attributes %}{{ content_attributes.addClass('card') }}{% else %} class="card"{% endif %}>
    <div class="card-body">
      {% if title|render %}
      <h3 class="card-title">{{ title }}</h3>
      {% endif %}

      {% if card_type == 'plus' and body|render  %}
        <div class="card-text">{{ body|raw }}</div>
      {% endif %}
      
      {% if more_content|render or (link_text and link_url) %}
      <div class="card-more-content">
        {% if more_content|render %}
        {{ more_content|raw }}
        {% endif %}

        {% if link_text and link_url %}
          <div class="field field--name-field-provus-links field--type-link field__items">
            <a href="{{ link_url }}" class="{{ link_style ? 'btn btn-' ~ link_style : '' }}">{{ link_text }}</a>
          </div>
        {% endif %}
      </div>  
      {% endif %}

    </div>
  </div>
</div>